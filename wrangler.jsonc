{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dream-believers-intro-quiz",
  "main": "worker/index.ts",
  "compatibility_date": "2025-06-29",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "routes": [
    {
      "pattern": "intro-quiz.sukisuki.club",
      "custom_domain": true
    }
  ]
  // D1 and R2 bindings will be added in a subsequent task.
}
